{
  "name": "@hdt/desktop",
  "version": "0.6.0",
  "private": true,
  "description": "OpenDeckTracker desktop app",
  "author": "OpenDeckTracker",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "predev": "pnpm run rebuild:native",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "rebuild:node": "pnpm rebuild better-sqlite3",
    "pretest": "pnpm run rebuild:node",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepare:native-runtime": "node scripts/prepare-native-runtime.mjs",
    "package": "electron-vite build && pnpm run prepare:native-runtime && electron-builder --config electron-builder.yml --win"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "electron-updater": "^6.8.3",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@hdt/core": "workspace:*",
    "@hdt/hearthdb": "workspace:*",
    "@hdt/hearthmirror": "workspace:*",
    "@hdt/hearthmirror-native": "workspace:*",
    "@hdt/hearthwatcher": "workspace:*",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-tabs": "^1.1.13",
    "@testing-library/react": "^15.0.7",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "^4.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^37.2.6",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.14.1",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.4.2",
    "zustand": "^5.0.12"
  }
}
