<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        Dev-only entitlements for the spike Electron run.

        task_for_pid path:
          - cs.debugger              required to call task_for_pid against
                                     a process we don't own (Hearthstone).
          - get-task-allow           lets us be debugged ourselves; not
                                     strictly needed for the spike but
                                     useful when poking with lldb.

        Electron 37 / V8 (Hardened Runtime) path:
          - cs.allow-jit                            V8 needs RWX pages.
          - cs.allow-unsigned-executable-memory     fallback when JIT
                                                    pages aren't tagged.
          - cs.disable-library-validation           lets the unsigned
                                                    napi-rs .node addon
                                                    load inside Electron.

        These four CS flags MUST stay in sync with whatever Apple
        ships in Electron's default Helper entitlements file —
        otherwise our re-sign overwrites the original signature with
        a strictly weaker grant set and Electron crashes on launch.
    -->
    <key>com.apple.security.cs.debugger</key>
    <true/>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <key>com.apple.security.get-task-allow</key>
    <true/>
</dict>
</plist>
