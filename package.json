{
  "name": "opendecktracker",
  "version": "0.6.0",
  "private": true,
  "type": "module",
  "description": "OpenDeckTracker — TypeScript Hearthstone deck tracker",
  "packageManager": "pnpm@10.10.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "preinstall": "npx -y only-allow pnpm",
    "dev": "pnpm --filter @hdt/desktop dev",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck",
    "pretest": "pnpm rebuild better-sqlite3",
    "test": "vitest run",
    "package": "pnpm --filter @hdt/desktop package",
    "cards:convert": "tsx scripts/convert-hsdata-cards.ts",
    "cards:download": "tsx scripts/download-cards.ts",
    "cards:images": "tsx scripts/download-card-images.ts",
    "notices": "node scripts/generate-third-party-notices.mjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "electron-winstaller",
      "esbuild",
      "@swc/core"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "saxes": "^6.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^2.1.9"
  }
}
